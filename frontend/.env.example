# API Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Application Settings
VITE_APP_NAME=Agentic AI Framework

# Authentication
VITE_AUTH_ENABLED=true

# Mock Service Worker (for development without backend)
# Set to 'true' to use mocked responses (no backend needed)
# Set to 'false' to use real backend at VITE_API_URL
# Or use: npm run dev:mock / npm run dev:real
VITE_ENABLE_MOCKS=false
