# Application
APP_NAME=Agentic AI Framework
VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# CORS - comma-separated list of allowed origins
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# Authentication
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# MongoDB
# For docker-compose setup with authentication:
MONGODB_URI=mongodb://admin:admin123@localhost:27017
# For local MongoDB without authentication:
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=agentic_ai

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# =============================================================================
# LLM Configuration (Global)
# =============================================================================
# Choose your LLM provider: ollama | openai | aws_bedrock
LLM_PROVIDER=ollama

# Default model for the chosen provider
# Examples:
#   Ollama: llama3, llama3.2, mistral, codellama
#   OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
#   Bedrock: anthropic.claude-v2, anthropic.claude-3-sonnet-20240229-v1:0
LLM_DEFAULT_MODEL=llama3

# LLM parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=120.0

# -----------------------------------------------------------------------------
# Ollama Configuration (default provider)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# AWS Bedrock Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_MODEL=anthropic.claude-v2

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Platform-specific LLM Overrides (Optional)
# =============================================================================
# Platforms can override global LLM settings with their own prefix
# Example: Hello World Platform can use a different provider/model

# HELLO_WORLD_LLM_PROVIDER=openai
# HELLO_WORLD_LLM_MODEL=gpt-4
# HELLO_WORLD_LLM_TEMPERATURE=0.8
# HELLO_WORLD_LLM_MAX_TOKENS=500
